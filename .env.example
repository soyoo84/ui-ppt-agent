# ==============================================================================
# [필수 설정] API 통신 및 모델 설정
# ==============================================================================
HCP_API_URL=base_url를 넣으세요
# 사내망 HCP API 통신 키 (필수)
HCP_API_KEY=your_api_key_here_이곳에_실제_키를_넣고_파일이름을_.env로_바꾸세요
# 캡처 화면을 분석하고 뼈대 구조(JSON)를 추출할 Vision 모델명
HCP_VISION_MODEL=qwen-2.5-vl
# 추출된 뼈대를 바탕으로 프론트엔드 코드(React/HTML)를 작성할 Text 모델명
HCP_TEXT_MODEL=qwen-3.5

# ==============================================================================
# [선택 설정] 아래부터는 주석(#)을 풀고 값을 변경하여 시스템을 튜닝할 수 있습니다.
# ==============================================================================

# [LLM 하이퍼파라미터 설정]
# API 호출 실패 시 최대 재시도 횟수
# LLM_MAX_RETRIES=3
# API 응답 대기 최대 시간 (초) - 이미지 분석 시간을 고려하여 넉넉히 설정 권장
# LLM_TIMEOUT_SECONDS=120.0
# 출력할 최대 토큰 수 (※ 4400 총 토큰 제한을 고려하여 1500~2000 유지 권장)
# LLM_MAX_TOKENS=1500
# 생성 결과의 창의성 조절 (0.0~1.0). 정형화된 JSON 추출을 위해 낮게(0.1) 유지
# LLM_TEMPERATURE=0.1

# [Frontend 설정]
# Streamlit 브라우저 탭 및 화면 상단에 표시될 앱 제목
# APP_TITLE=UI-PPT 자동 생성기

# [PPT 템플릿 및 레이아웃 설정]
# (선택) 단일 마스터 PPT 파일 경로 직접 지정 시 사용
# MASTER_PPT_PATH=
# 사내 PPT 템플릿(.pptx)들이 모여 있는 폴더명 (앱 UI에서 선택 가능)
# MASTER_TEMPLATE_DIR=master
# 템플릿 적용 시 기본으로 렌더링할 슬라이드 레이아웃 이름 (예: "제목 및 내용")
# TARGET_LAYOUT_NAME=

# [PPT 렌더링 세부 수치 설정]
# 슬라이드 가로 크기 (16:9 비율 기본값: 13.333 인치)
# PPT_SLIDE_WIDTH=13.333
# 슬라이드 세로 크기 (16:9 비율 기본값: 7.5 인치)
# PPT_SLIDE_HEIGHT=7.5
# PPT 슬라이드 내 UI 화면 렌더링 크기 비율 (기본 0.65 = 65% 크기로 축소)
# PPT_UI_SCALE=0.65
# PPT 슬라이드 내 UI 화면의 상단 여백 비율
# PPT_TOP_OFFSET_RATIO=0.25
# 컴포넌트 간 오차 보정(Snapping)을 통해 가로/세로 줄을 맞추는 임계값 (0.03 = 3% 오차 허용)
# PPT_ALIGN_THRESHOLD=0.03
# UI 화면 배경 패널의 내부 여백(Padding) 비율
# PPT_CONTAINER_PADDING=0.03

# [디자인 기본값 설정]
# 스캔된 토큰이 없을 때 적용될 사내 브랜드 메인 컬러 (R,G,B 쉼표 형식으로 입력)
# HDS_PRIMARY_COLOR_RGB=230,0,18
